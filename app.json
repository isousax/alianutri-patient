{
  "expo": {
    "name": "AliaPatient",
    "slug": "alianutri-patient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/alianutriIconWhite.png",
    "scheme": "aliapatient",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/alianutriIconWhite.png",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alianutri.patient",
      "associatedDomains": [
        "applinks:app.alianutri.com.br"
      ],
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/alianutriIconWhite.png",
        "backgroundColor": "#10B981"
      },
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.alianutri.patient",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.alianutri.com.br",
              "pathPrefix": "/p/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
